# ==================== SERVICE CONNECT - ENVIRONMENT VARIABLES ====================
# Copy this file to .env and fill in your actual values
# DO NOT commit the actual .env file to git!

# ==================== SERVER CONFIGURATION ====================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ==================== MYSQL DATABASE CONFIGURATION ====================
# Make sure MySQL is installed and running
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=service_connect

# ==================== JWT CONFIGURATION ====================
# Generate a strong random string for JWT_SECRET (min 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_min_32_chars_long_!
JWT_EXPIRE=7d

# ==================== EMAIL CONFIGURATION (OPTIONAL) ====================
# For sending emails (password reset, verification, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ==================== LOGGING CONFIGURATION ====================
LOG_LEVEL=info
# Options: error, warn, info, debug, verbose
